  </script>

  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6349270729296966" crossorigin="anonymous"></script>

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="64x64" href="/favicon-64x64.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180x180.png">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles/ride-modal.css?v=2">
  
  <style>
    :root {
      /* Brand Colors */
      --primary-blue: #4A9DE8;
      --action-orange: #F37021;
      --deep-purple: #5A4FCF;
      --splash-teal: #38B2AC;
      --base-dark: #2D3748;
      --bg-off-white: #F8F9FA;
      
      --white: #FFFFFF;
      --gray-100: #F7FAFC;
      --gray-200: #EDF2F7;
      --gray-300: #E2E8F0;
      --gray-400: #CBD5E0;
      --gray-500: #A0AEC0;
      --gray-600: #718096;
      --gray-700: #4A5568;
      
      /* Typography */
      --font-heading: 'Nunito', sans-serif;
      --font-body: 'Inter', sans-serif;
      
      /* Spacing */
      --space-xs: 0.25rem;
      --space-sm: 0.5rem;
      --space-md: 1rem;
      --space-lg: 1.5rem;
      --space-xl: 2rem;
      --space-2xl: 3rem;
      
      /* Radius */
      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 16px;
      --radius-xl: 24px;
      --radius-full: 9999px;
      
      /* Shadows */
      --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.04);
      --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.08);
      --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.12);
      --shadow-orange: 0 4px 12px rgba(243, 112, 33, 0.3);
    }
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    html {
      scroll-behavior: smooth;
    }
    
    body {
      font-family: var(--font-body);
      background: var(--bg-off-white);
      color: var(--base-dark);
      line-height: 1.6;
      min-height: 100vh;
    }
    
    /* Layout Container */
    .layout {
      max-width: 1400px;
      margin: 0 auto;
      display: flex;
      gap: var(--space-xl);
      padding: var(--space-xl);
    }
    
    /* Sidebar */
    .sidebar {
      width: 280px;
      flex-shrink: 0;
      position: sticky;
      top: 100px;
      height: fit-content;
    }
    
    .sidebar-section {
      background: var(--white);
      border-radius: var(--radius-lg);
      padding: var(--space-lg);
      margin-bottom: var(--space-lg);
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--gray-200);
    }
    
    .sidebar-title {
      font-family: var(--font-heading);
      font-size: 1rem;
      font-weight: 700;
      color: var(--base-dark);
      margin-bottom: var(--space-md);
    }
    
    /* Height Filter - Visual Ruler */
    .height-filter {
      margin-bottom: var(--space-lg);
    }
    
    .height-display {
      font-family: var(--font-heading);
      font-size: 2rem;
      font-weight: 800;
      color: var(--action-orange);
      text-align: center;
      margin-bottom: var(--space-md);
    }
    
    .height-display span {
      font-size: 1rem;
      color: var(--gray-500);
      font-weight: 600;
    }
    
    .height-ruler {
      position: relative;
      height: 40px;
      background: linear-gradient(to right, var(--splash-teal) 0%, var(--primary-blue) 50%, var(--action-orange) 100%);
      border-radius: var(--radius-full);
      margin-bottom: var(--space-sm);
    }
    
    .height-ruler-marks {
      display: flex;
      justify-content: space-between;
      padding: 0 10px;
      font-size: 0.625rem;
      color: var(--gray-500);
      font-weight: 600;
    }
    
    input[type="range"] {
      -webkit-appearance: none;
      width: 100%;
      height: 40px;
      background: transparent;
      border-radius: var(--radius-full);
      outline: none;
      position: absolute;
      top: 0;
      left: 0;
      margin: 0;
    }
    
    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 24px;
      height: 24px;
      background: var(--white);
      border: 3px solid var(--action-orange);
      border-radius: 50%;
      cursor: pointer;
      box-shadow: var(--shadow-md);
    }
    
    input[type="range"]::-moz-range-thumb {
      width: 24px;
      height: 24px;
      background: var(--white);
      border: 3px solid var(--action-orange);
      border-radius: 50%;
      cursor: pointer;
      box-shadow: var(--shadow-md);
    }
    
    /* Filter Chips */
    .filter-chips {
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
    }
    
    .filter-chip {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      padding: var(--space-md);
      background: var(--gray-100);
      border: 2px solid var(--gray-200);
      border-radius: var(--radius-md);
      cursor: pointer;
      transition: all 0.2s ease;
      font-family: var(--font-body);
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--gray-600);
      text-align: left;
    }
    
    .filter-chip:hover {
      border-color: var(--gray-300);
      background: var(--gray-200);
    }
    
    .filter-chip.active {
      background: rgba(243, 112, 33, 0.1);
      border-color: var(--action-orange);
      color: var(--action-orange);
    }
    
    .filter-chip svg {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
    }
    
    /* Ticket Cards */
    .ticket-cards {
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
    }
    
    .ticket-card {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      padding: var(--space-md);
      border-radius: var(--radius-md);
      text-decoration: none;
      color: white;
      font-weight: 600;
      font-size: 0.875rem;
      transition: all 0.2s ease;
      box-shadow: var(--shadow-sm);
    }
    
    .ticket-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }
    
    .ticket-card.disney {
      background: linear-gradient(135deg, #1a5fb4 0%, #3584e4 100%);
    }
    
    .ticket-card.universal {
      background: linear-gradient(135deg, #c01c28 0%, #e66100 100%);
    }
    
    .ticket-card.seaworld {
      background: linear-gradient(135deg, #26a269 0%, #1c71d8 100%);
    }
    
    .ticket-card.legoland {
      background: linear-gradient(135deg, #e3000f 0%, #f5c211 100%);
    }
    
    .ticket-card img {
      width: 32px;
      height: 32px;
      border-radius: var(--radius-sm);
      object-fit: cover;
    }
    
    /* Main Content */
    .main {
      flex: 1;
      min-width: 0;
    }
    
    /* Hero */
    .hero {
      text-align: center;
      margin-bottom: var(--space-xl);
      padding: var(--space-lg) 0;
    }
    
    .hero-title {
      font-family: var(--font-heading);
      font-size: 2.5rem;
      font-weight: 800;
      margin-bottom: var(--space-xs);
      color: var(--base-dark);
    }
    
    .hero-title span {
      color: var(--action-orange);
    }
    
    .hero-subtitle {
      font-size: 1.125rem;
      color: var(--gray-600);
      margin-bottom: var(--space-lg);
    }
    
    .total-counter {
      display: inline-flex;
      align-items: center;
      gap: var(--space-sm);
      background: var(--white);
      padding: var(--space-sm) var(--space-lg);
      border-radius: var(--radius-full);
      border: 1px solid var(--gray-200);
      box-shadow: var(--shadow-sm);
    }
    
    .total-counter .label {
      font-size: 0.75rem;
      color: var(--gray-500);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-weight: 600;
    }
    
    .total-counter .count {
      font-family: var(--font-heading);
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--action-orange);
    }
    
    .total-counter .count.total {
      color: var(--gray-500);
      font-size: 1.25rem;
    }
    
    /* Results Bar */
    .results-bar {
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-md);
      background: var(--white);
      padding: var(--space-md) var(--space-xl);
      border-radius: var(--radius-lg);
      border: 1px solid var(--gray-200);
      box-shadow: var(--shadow-sm);
    }
    
    .results-total {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
    }
    
    .results-total .count {
      font-family: var(--font-heading);
      font-size: 2rem;
      font-weight: 800;
      color: var(--action-orange);
    }
    
    .results-total .count.total {
      color: var(--gray-500);
      font-size: 1.5rem;
    }
    
    .results-total .label {
      font-size: 0.875rem;
      color: var(--gray-500);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-weight: 600;
    }
    
    .parent-breakdown {
      display: flex;
      gap: var(--space-lg);
      padding-top: var(--space-md);
      border-top: 1px solid var(--gray-200);
    }
    
    .parent-stat {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    
    .gauge-icon {
      width: 40px;
      height: 24px;
    }
    
    .parent-name {
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--gray-600);
    }
    
    .parent-fraction {
      font-family: var(--font-heading);
      font-size: 1rem;
      font-weight: 700;
      color: var(--base-dark);
    }
    
    @media (max-width: 640px) {
      .parent-breakdown {
        flex-direction: column;
        gap: var(--space-sm);
      }
    }
    
    /* Park Grid */
    .parks-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: var(--space-lg);
    }
    
    /* Park Cards */
    .park-card {
      display: block;
      background: var(--white);
      border-radius: var(--radius-lg);
      border: 1px solid var(--gray-200);
      overflow: hidden;
      transition: all 0.3s ease;
      cursor: pointer;
      box-shadow: var(--shadow-sm);
      text-decoration: none;
      color: inherit;
    }
    
    .park-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-lg);
      border-color: var(--gray-300);
    }
    
    .park-card-image {
      height: 140px;
      background-size: cover;
      background-position: center;
      position: relative;
    }
    
    .park-card-image::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.6) 100%);
    }
    
    .park-card-content {
      padding: var(--space-lg);
    }
    
    .park-card-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: var(--space-sm);
    }
    
    .park-card h3 {
      font-family: var(--font-heading);
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--base-dark);
      margin: 0;
    }
    
    .park-card .resort {
      font-size: 0.75rem;
      color: var(--gray-500);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-weight: 600;
      margin-bottom: var(--space-md);
    }
    
    .ride-count-badge {
      display: flex;
      align-items: center;
      gap: var(--space-xs);
      font-family: var(--font-heading);
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--action-orange);
    }
    
    .ride-count-badge span {
      font-size: 0.875rem;
      color: var(--gray-400);
      font-weight: 600;
    }
    
    .ride-chips {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-xs);
    }
    
    .ride-chip {
      font-size: 0.75rem;
      padding: var(--space-xs) var(--space-sm);
      background: var(--gray-100);
      border-radius: var(--radius-sm);
      color: var(--gray-600);
      white-space: nowrap;
    }
    
    .more-rides {
      font-size: 0.75rem;
      padding: var(--space-xs) var(--space-sm);
      background: transparent;
      border: 1px dashed var(--gray-300);
      border-radius: var(--radius-sm);
      color: var(--gray-400);
    }
    
    /* Amazon Ad Section */
    .amazon-ad-section {
      min-height: 250px;
    }
    
    .amazon-ad-section iframe,
    .amazon-ad-section div[id^="amzn"] {
      width: 100% !important;
      max-width: 100%;
    }
    
    /* Amazon Products Section */
    .amazon-products .product-links {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    
    .amazon-products .product-link {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem;
      background: var(--gray-100);
      border-radius: var(--radius-sm);
      text-decoration: none;
      color: var(--base-dark);
      font-size: 0.8125rem;
      transition: background 0.2s;
    }
    
    .amazon-products .product-link:hover {
      background: var(--gray-200);
    }
    
    .amazon-products .product-link span {
      font-size: 1.25rem;
    }
    
    /* Park Detail View */
    .park-detail {
      display: none;
    }
    
    .park-detail.active {
      display: block;
      animation: fadeIn 0.3s ease;
    }
    
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    
    .back-btn {
      display: inline-flex;
      align-items: center;
      gap: var(--space-sm);
      padding: var(--space-sm) var(--space-md);
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: var(--radius-full);
      color: var(--gray-600);
      font-size: 0.875rem;
      cursor: pointer;
      margin-bottom: var(--space-lg);
      transition: all 0.2s ease;
      font-family: var(--font-body);
      font-weight: 500;
    }
    
    .back-btn:hover {
      background: var(--gray-100);
      color: var(--base-dark);
    }
    
    .park-hero {
      padding: var(--space-2xl);
      border-radius: var(--radius-xl);
      margin-bottom: var(--space-xl);
      background-size: cover;
      background-position: center;
      position: relative;
      color: white;
    }
    
    .park-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.5);
      border-radius: var(--radius-xl);
    }
    
    .park-hero-content {
      position: relative;
      z-index: 1;
    }
    
    .park-hero .resort {
      font-size: 0.875rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-weight: 600;
      opacity: 0.9;
      margin-bottom: var(--space-sm);
    }
    
    .park-hero h2 {
      font-family: var(--font-heading);
      font-size: 2.5rem;
      font-weight: 800;
      margin-bottom: var(--space-lg);
    }
    
    .stats-row {
      display: flex;
      gap: var(--space-xl);
      margin-bottom: var(--space-lg);
    }
    
    .stat {
      display: flex;
      flex-direction: column;
    }
    
    .stat-value {
      font-family: var(--font-heading);
      font-size: 2rem;
      font-weight: 800;
    }
    
    .stat-label {
      font-size: 0.875rem;
      opacity: 0.8;
    }
    
    .affiliate-btn {
      display: inline-flex;
      align-items: center;
      gap: var(--space-sm);
      padding: var(--space-md) var(--space-xl);
      background: var(--action-orange);
      color: white;
      text-decoration: none;
      border-radius: var(--radius-full);
      font-weight: 600;
      font-size: 1rem;
      transition: all 0.2s ease;
      box-shadow: var(--shadow-orange);
      border: none;
      cursor: pointer;
      font-family: var(--font-body);
    }
    
    .affiliate-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(243, 112, 33, 0.4);
    }
    
    /* Ride Grid */
    .ride-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: var(--space-lg);
    }
    
    /* Ride Cards */
    .ride-card {
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: var(--radius-lg);
      padding: var(--space-lg);
      transition: all 0.2s ease;
      box-shadow: var(--shadow-sm);
    }
    
    .ride-card:hover {
      border-color: var(--gray-300);
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }
    
    .ride-card.unavailable {
      opacity: 0.6;
      background: var(--gray-100);
    }
    
    .ride-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: var(--space-sm);
      gap: var(--space-sm);
    }
    
    .ride-name {
      font-family: var(--font-heading);
      font-size: 1.125rem;
      font-weight: 700;
      color: var(--base-dark);
      flex: 1;
    }
    
    .ride-card.unavailable .ride-name {
      color: var(--gray-500);
    }
    
    .ride-type {
      font-size: 0.75rem;
      color: var(--gray-500);
      background: var(--gray-100);
      padding: var(--space-xs) var(--space-sm);
      border-radius: var(--radius-sm);
      font-weight: 500;
      white-space: nowrap;
    }
    
    .unavailable-badge {
      font-size: 0.7rem;
      padding: var(--space-xs) var(--space-sm);
      background: rgba(192, 28, 40, 0.1);
      color: #c01c28;
      border-radius: var(--radius-full);
      font-weight: 600;
      white-space: nowrap;
    }
    
    .ride-description {
      font-size: 0.875rem;
      color: var(--gray-600);
      margin-bottom: var(--space-md);
      line-height: 1.5;
    }
    
    .ride-card.unavailable .ride-description {
      color: var(--gray-400);
    }
    
    .ride-meta {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-md);
      margin-bottom: var(--space-md);
    }
    
    .meta-item {
      display: flex;
      align-items: center;
      gap: var(--space-xs);
      font-size: 0.75rem;
      color: var(--gray-500);
    }
    
    .ride-tags {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-xs);
    }
    
    .tag {
      font-size: 0.75rem;
      padding: var(--space-xs) var(--space-sm);
      border-radius: var(--radius-full);
      font-weight: 600;
    }
    
    .tag-height {
      background: rgba(243, 112, 33, 0.1);
      color: var(--action-orange);
    }
    
    .tag-pregnancy {
      background: rgba(56, 178, 172, 0.1);
      color: var(--splash-teal);
    }
    
    .tag-wheelchair {
      background: rgba(74, 157, 232, 0.1);
      color: var(--primary-blue);
    }
    
    .tag-sensory-dark {
      background: rgba(90, 79, 207, 0.1);
      color: var(--deep-purple);
    }
    
    .tag-sensory-loud,
    .tag-sensory-sudden,
    .tag-sensory-strobe {
      background: rgba(243, 112, 33, 0.1);
      color: var(--action-orange);
    }
    
    .tag-sensory-enclosed {
      background: rgba(45, 55, 72, 0.1);
      color: var(--base-dark);
    }
    
