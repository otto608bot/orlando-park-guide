  <meta property="twitter:title" content="{% if title %}{{ title }}{% else %}Plan Your Park - Orlando Ride Guide{% endif %}">
  <meta property="twitter:description" content="Find perfect rides at Disney World, Universal Orlando, SeaWorld & LEGOLAND. Filter by height, pregnancy safety, wheelchair accessibility, and sensory needs.">
  <meta property="twitter:image" content="https://planyourpark.com/logo-full.png">
  
  <!-- Canonical URL -->
  <link rel="canonical" href="https://planyourpark.com{% if page.url %}{{ page.url }}{% endif %}">
  
