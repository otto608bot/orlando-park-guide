<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Plan Your Park</title>
  <meta name="description" content="{{ description | default('Your ultimate guide to Orlando theme parks - Disney World, Universal, SeaWorld & more!') }}">
  
  <!-- Favicons -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="64x64" href="/favicon/favicon-64x64.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon/favicon-180x180.png">
  
  <link rel="stylesheet" href="/styles/global-nav.css">
  <link rel="stylesheet" href="/styles/ride-modal.css">
</head>
<body>
  {{ content | safe }}
  <script src="/scripts/shared-nav.js" defer></script>
  <script src="/scripts/global-nav.js" defer></script>
  <script src="/scripts/filter-system.js" defer></script>
  <script src="/scripts/ride-modal.js" defer></script>
  <script src="/scripts/ride-images.js" defer></script>
  <script src="/scripts/app.js" defer onload="console.log('App Loaded')"></script>
</body>
</html>
