  <!-- Filter System Integration -->
  <script>
    (function() {
      // Initialize FilterSystem and sync with app.js state
      FilterSystem.init(function(filterState) {
        // Sync FilterSystem state to app.js state
        if (typeof state !== 'undefined' && state.filters) {
          state.filters.height = filterState.height;
          state.filters.pregnancy = filterState.pregnancy;
          // Convert 'WAV'/'any' to boolean for app.js
          state.filters.wheelchair = filterState.wheelchair === 'WAV';
          // Convert sensory object to boolean for app.js (true if any sensory filter is active)
          state.filters.sensory = Object.values(filterState.sensory).some(v => v);
          
          // Trigger re-render
          if (typeof render === 'function') render();
        }
      });
      
      // Wrap app.js toggleFilter to sync back to FilterSystem
      const originalToggleFilter = window.toggleFilter;
      window.toggleFilter = function(type) {
        // Call original function
        if (originalToggleFilter) originalToggleFilter(type);
        
        // Sync to FilterSystem
        if (type === 'pregnancy') {
          FilterSystem.togglePregnancy();
        } else if (type === 'wheelchair') {
          // Toggle between 'any' and 'WAV'
          const current = FilterSystem.getState().wheelchair;
          FilterSystem.setWheelchair(current === 'WAV' ? 'any' : 'WAV');
        } else if (type === 'sensory') {
          FilterSystem.toggleAllSensory();
        }
      };
      
      // Sync initial state from FilterSystem to app.js
      const initialState = FilterSystem.getState();
      if (typeof state !== 'undefined' && state.filters) {
        state.filters.height = initialState.height;
        state.filters.pregnancy = initialState.pregnancy;
        state.filters.wheelchair = initialState.wheelchair === 'WAV';
        state.filters.sensory = Object.values(initialState.sensory).some(v => v);
      }
    })();
  </script>
  
  <!-- Global Navigation Manager -->
  <script>
    // Global Navigation Manager
    window.GlobalNav = {
      currentPage: '',
      
      init(page) {
        this.currentPage = page;
        this.setActiveNav(page);
        
        // Show filter button on pages that need it (mobile only)
        if (page === 'rides' || page === 'dining') {
          const filterBtn = document.getElementById('global-filter-btn');
          if (filterBtn && window.innerWidth <= 1024) {
            filterBtn.style.display = 'flex';
          }
        }
      },
      
      setActiveNav(page) {
        // Desktop nav
        const navIds = {
          'home': 'nav-home',
          'rides': 'nav-rides',
          'dining': 'nav-dining',
          'blog': 'nav-blog'
        };
        
        // Mobile nav
        const mobileNavIds = {
          'home': 'mobile-nav-home',
          'rides': 'mobile-nav-rides',
          'dining': 'mobile-nav-dining',
          'blog': 'mobile-nav-blog'
        };
        
        // Set active class
        const activeNav = document.getElementById(navIds[page]);
        const activeMobileNav = document.getElementById(mobileNavIds[page]);
        
        if (activeNav) activeNav.classList.add('active');
        if (activeMobileNav) activeMobileNav.classList.add('active');
      },
      
      openNav() {
        const sheet = document.getElementById('global-mobile-nav-sheet');
        if (sheet) {
          sheet.classList.add('active');
          document.body.style.overflow = 'hidden';
        }
      },
      
      closeNav(event) {
        const sheet = document.getElementById('global-mobile-nav-sheet');
        if (!event || event.target === sheet) {
          if (sheet) {
            sheet.classList.remove('active');
            document.body.style.overflow = '';
          }
        }
      },
      
      openFilters() {
        // Open the filter sheet directly
        const sheet = document.getElementById('filter-mobile-sheet');
        if (sheet) {
          sheet.classList.add('active');
          document.body.style.overflow = 'hidden';
        }
        // Also dispatch event for any listeners
        document.dispatchEvent(new CustomEvent('global:openFilters'));
      },
      
      closeFilters() {
        // Close the filter sheet directly
        const sheet = document.getElementById('filter-mobile-sheet');
        if (sheet) {
          sheet.classList.remove('active');
          document.body.style.overflow = '';
        }
        // Also dispatch event for any listeners
        document.dispatchEvent(new CustomEvent('global:closeFilters'));
      }
    };

    // Close on escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        GlobalNav.closeNav();
      }
    });

    // Toggle mobile parks section
    function toggleMobileParksSection() {
      const section = document.getElementById('mobile-parks-section');
      if (section) {
        section.classList.toggle('expanded');
      }
    }
    window.toggleMobileParksSection = toggleMobileParksSection;
    
    // Initialize for home page
    GlobalNav.init('home');
    
    // Handle resize to show/hide filter button
    window.addEventListener('resize', function() {
      const filterBtn = document.getElementById('global-filter-btn');
      if (filterBtn) {
        filterBtn.style.display = window.innerWidth <= 1024 ? 'flex' : 'none';
      }
    });
    
    // Connect global filter events to rides page filter functions
    document.addEventListener('global:openFilters', function() {
      const sheet = document.getElementById('filter-mobile-sheet');
      if (sheet) {
        sheet.classList.add('active');
        document.body.style.overflow = 'hidden';
      }
    });
    
    document.addEventListener('global:closeFilters', function() {
      const sheet = document.getElementById('filter-mobile-sheet');
      if (sheet) {
        sheet.classList.remove('active');
        document.body.style.overflow = '';
      }
    });
  </script>
</body>
</html>
