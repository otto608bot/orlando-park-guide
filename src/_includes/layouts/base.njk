<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ ogUrl }}">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:image" content="https://planyourpark.com/logo-full.png">
  <meta property="og:site_name" content="Plan Your Park">
  
  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="{{ ogUrl }}">
  <meta property="twitter:title" content="{{ title }}">
  <meta property="twitter:description" content="{{ description }}">
  <meta property="twitter:image" content="https://planyourpark.com/logo-full.png">
  
  <!-- Canonical URL -->
  <link rel="canonical" href="{{ ogUrl }}">
  
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-SJHPEWNBLS"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-SJHPEWNBLS');
  </script>

  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6349270729296966" crossorigin="anonymous"></script>

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="64x64" href="/favicon-64x64.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180x180.png">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles/ride-modal.css?v=2">
</head>
<body>
  <header class="global-header">
    <div class="global-header-content">
      <button class="global-mobile-menu-btn" onclick="GlobalNav.openNav()" aria-label="Open menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
      
      <a href="/" class="global-logo">
        <img src="/logo-full.png" alt="Plan Your Park">
      </a>
      
      <nav class="global-nav">
        <a href="/" id="nav-home">Home</a>
        <div class="nav-dropdown">
          <button class="nav-dropdown-toggle" id="nav-parks" onclick="GlobalNav.toggleParksDropdown(event)">
            Parks
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="nav-dropdown-menu" id="parks-dropdown">
            <a href="/park/?park=magic-kingdom">Magic Kingdom</a>
            <a href="/park/?park=epcot">EPCOT</a>
            <a href="/park/?park=hollywood-studios">Hollywood Studios</a>
            <a href="/park/?park=animal-kingdom">Animal Kingdom</a>
            <a href="/park/?park=universal-studios">Universal Studios Florida</a>
            <a href="/park/?park=islands-of-adventure">Islands of Adventure</a>
            <a href="/park/?park=seaworld">SeaWorld Orlando</a>
            <a href="/park/?park=legoland">LEGOLAND Florida</a>
          </div>
        </div>
        <a href="/rides/" id="nav-rides">Rides</a>
        <a href="/character-dining/" id="nav-dining">Character Dining</a>
        <a href="/blog/" id="nav-blog">Blog</a>
        <a href="/deals/" id="nav-deals">Deals</a>
      </nav>
      
      <!-- Mobile filter button (shown via JS for rides/dining pages) -->
      <button class="global-mobile-filter-btn" id="global-filter-btn" onclick="GlobalNav.openFilters()" >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
        </svg>
        Filters
      </button>
    </div>
  </header>

  <!-- Mobile Navigation Sheet -->
  <div class="global-mobile-nav-sheet" id="global-mobile-nav-sheet" onclick="GlobalNav.closeNav(event)">
    <div class="global-mobile-nav-content" onclick="event.stopPropagation()">
      <div class="global-mobile-nav-header">
        <h3>Menu</h3>
        <button class="global-close-nav-btn" onclick="GlobalNav.closeNav()">&times;</button>
      </div>
      <nav class="global-mobile-nav-links">
        <a href="/" id="mobile-nav-home">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            <polyline points="9 22 9 12 15 12 15 22"></polyline>
          </svg>
          Home
        </a>
        <div class="mobile-nav-section expanded" id="mobile-parks-section">
          <div class="mobile-nav-section-header" onclick="toggleMobileParksSection()">
            <span class="mobile-nav-section-title">Parks</span>
            <svg class="mobile-nav-section-toggle" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </div>
          <div class="mobile-nav-section-content">
            <a href="/park/?park=magic-kingdom">Magic Kingdom</a>
            <a href="/park/?park=epcot">EPCOT</a>
            <a href="/park/?park=hollywood-studios">Hollywood Studios</a>
            <a href="/park/?park=animal-kingdom">Animal Kingdom</a>
            <a href="/park/?park=universal-studios">Universal Studios Florida</a>
            <a href="/park/?park=islands-of-adventure">Islands of Adventure</a>
            <a href="/park/?park=seaworld">SeaWorld Orlando</a>
            <a href="/park/?park=legoland">LEGOLAND Florida</a>
          </div>
        </div>
        <a href="/rides/" id="mobile-nav-rides">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M2 12h4l3-9 6 18 3-9h4"></path>
          </svg>
          Rides
        </a>
        <a href="/character-dining/" id="mobile-nav-dining">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 8h1a4 4 0 0 1 0 8h-1"></path>
            <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"></path>
            <line x1="6" y1="1" x2="6" y2="4"></line>
            <line x1="10" y1="1" x2="10" y2="4"></line>
            <line x1="14" y1="1" x2="14" y2="4"></line>
          </svg>
          Character Dining
        </a>
        <a href="/blog/" id="mobile-nav-blog">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="16" y1="13" x2="8" y2="13"></line>
            <line x1="16" y1="17" x2="8" y2="17"></line>
            <polyline points="10 9 9 9 8 9"></polyline>
          </svg>
          Blog
        </a>
        <a href="/deals/" id="mobile-nav-deals">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="9" cy="21" r="1"></circle>
            <circle cx="20" cy="21" r="1"></circle>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
          </svg>
          Deals
        </a>
      </nav>
    </div>
  </div>

  {{ content }}

  <script src="/scripts/global-nav.js?v=3"></script>
  <script src="/scripts/shared-nav.js?v=2"></script>
  <script>
    // Global Navigation Controller
    var GlobalNav = {
      isNavOpen: false,
      isFiltersOpen: false,
      
      init: function(page) {
        // Set active nav item
        if (page) {
          var navItem = document.getElementById('nav-' + page);
          if (navItem) {
            navItem.classList.add('active');
          }
        }
        
        // Close nav on escape
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') {
            this.closeNav();
          }
        }.bind(this));
      },
      
      openNav: function() {
        var sheet = document.getElementById('global-mobile-nav-sheet');
        if (sheet) {
          sheet.classList.add('active');
          document.body.style.overflow = 'hidden';
          this.isNavOpen = true;
        }
      },
      
      closeNav: function(event) {
        if (event && event.target !== document.getElementById('global-mobile-nav-sheet')) {
          return;
        }
        var sheet = document.getElementById('global-mobile-nav-sheet');
        if (sheet) {
          sheet.classList.remove('active');
          document.body.style.overflow = '';
          this.isNavOpen = false;
        }
      },
      
      toggleParksDropdown: function(event) {
        event.stopPropagation();
        var dropdown = document.getElementById('parks-dropdown');
        if (dropdown) {
          dropdown.classList.toggle('active');
        }
      },
      
      openFilters: function() {
        var sheet = document.getElementById('filter-mobile-sheet');
        if (sheet) {
          sheet.classList.add('active');
          document.body.style.overflow = 'hidden';
          this.isFiltersOpen = true;
        }
      },
      
      closeFilters: function() {
        var sheet = document.getElementById('filter-mobile-sheet');
        if (sheet) {
          sheet.classList.remove('active');
          document.body.style.overflow = '';
          this.isFiltersOpen = false;
        }
      },
      
      handleResize: function() {
        // For future responsive handling
      }
    };

    // Make GlobalNav available globally
    window.GlobalNav = GlobalNav;

    // Initialize when DOM is ready
    document.addEventListener('DOMContentLoaded', function() {
      // Close nav on outside click
      document.addEventListener('click', function(event) {
        var sheet = document.getElementById('global-mobile-nav-sheet');
        var menuBtn = document.querySelector('.global-mobile-menu-btn');
        if (sheet && sheet.classList.contains('active')) {
          if (!sheet.contains(event.target) && !menuBtn.contains(event.target)) {
            GlobalNav.closeNav();
          }
        }
      });

      // Close dropdowns on outside click
      document.addEventListener('click', function(event) {
        var dropdown = document.getElementById('parks-dropdown');
        var toggle = document.querySelector('.nav-dropdown-toggle');
        if (dropdown && dropdown.classList.contains('active')) {
          if (!dropdown.contains(event.target) && !toggle.contains(event.target)) {
            dropdown.classList.remove('active');
          }
        }
      });

      // Dispatch ready event
      document.dispatchEvent(new CustomEvent('nav:ready'));
    });

    // Close nav function for onclick handlers
    function closeNav(event) {
      if (event) {
        event.stopPropagation();
      }
      var sheet = document.getElementById('global-mobile-nav-sheet');
      if (sheet) {
        sheet.classList.remove('active');
        document.body.style.overflow = '';
      }
      // Also close filters if open
      var filterSheet = document.getElementById('filter-mobile-sheet');
      if (filterSheet) {
        filterSheet.classList.remove('active');
        document.body.style.overflow = '';
      }
      // Dispatch event for any listeners
      document.dispatchEvent(new CustomEvent('global:closeFilters'));
    }
    window.closeNav = closeNav;

    // Toggle mobile parks section
    function toggleMobileParksSection() {
      const section = document.getElementById('mobile-parks-section');
      if (section) {
        section.classList.toggle('expanded');
      }
    }
    window.toggleMobileParksSection = toggleMobileParksSection;

    // Connect global filter events to rides page filter functions
    document.addEventListener('global:openFilters', function() {
      const sheet = document.getElementById('filter-mobile-sheet');
      if (sheet) {
        sheet.classList.add('active');
        document.body.style.overflow = 'hidden';
      }
    });
    
    document.addEventListener('global:closeFilters', function() {
      const sheet = document.getElementById('filter-mobile-sheet');
      if (sheet) {
        sheet.classList.remove('active');
        document.body.style.overflow = '';
      }
    });
  </script>
  
  <!-- Ride Detail Modal -->
  <div class="ride-modal-overlay" id="ride-modal" onclick="closeRideModal(event)">
    <div class="ride-modal-content" onclick="event.stopPropagation()">
      <button class="ride-modal-close" onclick="closeRideModal()">&times;</button>
      
      <div class="ride-modal-header">
        <div class="ride-modal-image-placeholder">[Ride Image]</div>
        <div class="ride-modal-title-section">
          <h2 id="modal-ride-name">Ride Name</h2>
          <span id="modal-ride-park">Park Name</span>
          <div class="ride-modal-height" id="modal-ride-height">48" minimum</div>
        </div>
      </div>
      
      <div class="ride-modal-body">
        <p id="modal-ride-description">Description...</p>
        
        <div class="ride-modal-section">
          <h3>Rider Tips</h3>
          <ul id="modal-ride-tips"></ul>
        </div>
        
        <div class="ride-modal-section">
          <h3>Best Time to Ride</h3>
          <p id="modal-ride-best-time">Morning</p>
        </div>
        
        <div class="ride-modal-section">
          <h3>Accessibility</h3>
          <div id="modal-ride-accessibility">
            <div>Wheelchair: <span id="modal-wheelchair"></span></div>
            <div id="modal-sensory-warnings"></div>
          </div>
        </div>
        
        <div class="ride-modal-section">
          <h3>Similar Rides</h3>
          <div id="modal-similar-rides"></div>
        </div>
        
        <a id="modal-ticket-link" href="#" class="ticket-button" target="_blank" rel="noopener noreferrer">Get Tickets for [Park]</a>
      </div>
    </div>
  </div>
  
  <script src="/scripts/ride-modal.js?v=2"></script>
</body>
</html>
